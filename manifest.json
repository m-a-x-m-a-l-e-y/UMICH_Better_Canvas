{
  "manifest_version": 3,
  "name": "UMich Canvas +",
  "version": "1.0",
  "permissions": ["storage","activeTab"],
  "host_permissions": [
    "https://maizepages.umich.edu/" 
  ],
  "icons": {
    "48": "48.png",
    "128": "128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Click to open popup",
    "default_icon": "48.png"

  },
  "content_scripts": [
    {
      "matches": ["https://umich.instructure.com/"],
      "js": ["eventClass.js", "content.js", "options.js"]
    }
  ]
  
}